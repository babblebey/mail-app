// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Further reading:
    // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
    // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
    url      = env("DATABASE_URL")
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String        @id @default(cuid())
    name          String?
    email         String?       @unique
    emailVerified DateTime?
    image         String?
    accounts      Account[]
    sessions      Session[]
    mailAccounts  MailAccount[]
}

model MailAccount {
    id        String   @id @default(cuid())
    label     String
    email     String

    // IMAP
    imapHost  String
    imapPort  Int      @default(993)
    imapTls   Boolean  @default(true)

    // SMTP
    smtpHost  String
    smtpPort  Int      @default(587)
    smtpTls   Boolean  @default(true)

    // Auth (shared for IMAP & SMTP unless we need to split later)
    username  String
    password  String   // encrypted at application level

    isDefault Boolean  @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId    String

    folders   MailFolder[]
    messages  MailMessage[]
    syncState SyncState?

    @@index([userId])
}

model MailFolder {
    id              String    @id @default(cuid())
    mailAccountId   String
    path            String
    name            String
    specialUse      String?
    delimiter       String?
    totalMessages   Int       @default(0)
    unseenMessages  Int       @default(0)
    uidValidity     Int?
    highestUid      Int       @default(0)
    lastSyncedAt    DateTime?

    mailAccount     MailAccount  @relation(fields: [mailAccountId], references: [id], onDelete: Cascade)
    messages        MailMessage[]

    @@unique([mailAccountId, path])
}

model MailMessage {
    id              String    @id @default(cuid())
    mailAccountId   String
    folderId        String
    uid             Int
    messageId       String?
    subject         String?
    fromAddress     Json
    toAddress       Json
    ccAddress       Json?
    bccAddress      Json?
    date            DateTime?
    flags           String[]
    read            Boolean   @default(false)
    starred         Boolean   @default(false)
    snippet         String?
    hasAttachments  Boolean   @default(false)
    inReplyTo       String?
    references      String[]
    bodyFetched     Boolean   @default(false)
    createdAt       DateTime  @default(now())
    updatedAt       DateTime  @updatedAt

    mailAccount     MailAccount     @relation(fields: [mailAccountId], references: [id], onDelete: Cascade)
    folder          MailFolder      @relation(fields: [folderId], references: [id], onDelete: Cascade)
    body            MailMessageBody?

    @@unique([folderId, uid])
    @@index([mailAccountId])
    @@index([folderId, date(sort: Desc)])
}

model MailMessageBody {
    id          String   @id @default(cuid())
    messageId   String   @unique
    textBody    String?
    htmlBody    String?
    attachments Json?
    fetchedAt   DateTime @default(now())

    message     MailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model SyncState {
    id                  String    @id @default(cuid())
    mailAccountId       String    @unique
    status              String    @default("idle")
    error               String?
    lastSyncStartedAt   DateTime?
    lastSyncCompletedAt DateTime?

    mailAccount         MailAccount @relation(fields: [mailAccountId], references: [id], onDelete: Cascade)
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}
